#!/usr/bin/env sh
# Pre-commit hook — keep cheap. Heavier checks live in CI.
#
# - Check that no link in AGENTS.md points to a missing file.
# - That's it for Phase 0. As gateway/ and web/ land, add lint-staged or
#   per-package hooks here.

set -e

if [ -f AGENTS.md ]; then
  grep -oE '\]\(\./[^)]+\)' AGENTS.md | sed -E 's|\]\(\./([^)]+)\)|\1|' | while read -r path; do
    if [ ! -e "$path" ]; then
      echo "pre-commit: broken AGENTS.md link → $path" >&2
      exit 1
    fi
  done
fi
