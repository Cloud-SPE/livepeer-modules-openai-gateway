{
  "name": "@livepeer-modules-openai/gateway",
  "version": "1.4.1",
  "description": "OpenAI Service — gateway: OpenAI-compatible proxy + SaaS shell, backed by Livepeer",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist",
    "migrations"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node ./dist/index.js",
    "dev": "node --watch --import tsx ./src/index.ts",
    "lint": "tsc --noEmit",
    "test": "rm -rf ./dist-test && tsc -p tsconfig.test.json && node --test ./dist-test/test/**/*.test.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^6.0.0",
    "js-yaml": "^4.1.0",
    "pg": "^8.13.0",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.2",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24"
  }
}
