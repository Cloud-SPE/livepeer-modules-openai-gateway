# OpenAI Service — env vars consumed by docker-compose.yml.
# Copy to `.env` and fill in.
#
# Default values (in compose) are dev-only. For production, set
# everything below.

# ── Postgres ────────────────────────────────────────────────────────
POSTGRES_DB=openai_service
POSTGRES_USER=openai_service
POSTGRES_PASSWORD=please-change-me
# ── Gateway HTTP ────────────────────────────────────────────────────
BASE_URL=https://example.com
PUBLIC_SITE_URL=https://example.com
PUBLIC_PORTAL_URL=https://example.com/portal/
ALLOWED_ORIGINS=https://example.com
LOG_LEVEL=info
GATEWAY_HOST_PORT=4001

# ── SaaS shell auth — REQUIRED in production ───────────────────────
ADMIN_TOKEN=
API_KEY_HASH_PEPPER=
IP_HASH_PEPPER=
METRICS_TOKEN=
SESSION_TTL_HOURS=24

# ── Email (optional — without this, verification + key emails log to
#    stdout instead of sending) ─────────────────────────────────────
RESEND_API_KEY=
RESEND_BASE_URL=https://api.resend.com/emails
FROM_EMAIL=OpenAI Service <noreply@example.com>

# ── LOC clearinghouse — REQUIRED ───────────────────────────────────
# The LOC (Livepeer Open Clearinghouse) owns route selection and
# payment minting; the gateway opens a job per upstream call and
# settles actual units afterwards. Get an API key from the LOC portal.
LOC_BASE_URL=https://loc.cloudspe.com
LOC_API_KEY=
LOC_TIMEOUT_MS=30000
# Background settler cadence + retry budget (refunds the unused part
# of each job's estimate; safe to leave at defaults).
LOC_SETTLE_INTERVAL_MS=15000
LOC_SETTLE_MAX_ATTEMPTS=20
# Job-open retries per request on 429/5xx (total attempts = retries+1).
LOC_JOB_RETRIES=2
# Offering id → runner serving name (JSON object). The offering id
# routes the LOC job, but brokers forward the JSON body verbatim to
# the runner, which only accepts its own model id (e.g. vLLM's name).
# Needed until the LOC exposes the registry's extra.openai.model.
LOC_MODEL_MAP={"some-offering-id":"Org/Model-Name"}
REGISTRY_REFRESH_INTERVAL_MS=60000

# ── /v1/* rate limit ──────────────────────────────────────────────
# Per-API-key token bucket. burst = max tokens accumulated;
# per_minute = refill rate.
V1_RATE_LIMIT_PER_MINUTE=60
V1_RATE_LIMIT_BURST=30

GATEWAY_TAG=dev
